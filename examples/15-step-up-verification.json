{
  "_comment": "HITL Protocol v0.8 — Example: Step-Up Verification for Inline Submit",
  "_spec": "https://github.com/rotorstar/hitl-protocol",
  "scenario": "A support bot can render inline buttons in Slack, but the service declares a step-up proof_of_human policy for inline_submit. A compliant agent preflights the policy and routes the human to review_url. An alternative non-compliant inline attempt receives 403 verification_required.",
  "steps": [
    {
      "step": 1,
      "description": "Service returns HTTP 202 with optional inline submit, but proof_of_human is configured as a step-up requirement for inline_submit.",
      "response": {
        "status": 202,
        "headers": {
          "Content-Type": "application/json",
          "Retry-After": "20"
        },
        "body": {
          "status": "human_input_required",
          "message": "Confirm sending a password reset to the customer.",
          "hitl": {
            "spec_version": "0.8",
            "case_id": "review_support_u7v8w9x0",
            "review_url": "https://support.example/review/support_u7v8w9x0?token=H1jK3lM5nO7pQ9rS1tU3vW5xY7zA9bC1dE3fG5h",
            "poll_url": "https://api.support.example/v1/reviews/support_u7v8w9x0/status",
            "submit_url": "https://api.support.example/v1/reviews/support_u7v8w9x0/submit",
            "submit_token": "agt_J1kL3mN5pQ7rS9tU1vW3xY5zA7bC9dE1fG3hI5j",
            "inline_actions": ["confirm", "cancel"],
            "verification_policy": {
              "mode": "step_up",
              "required_for": ["inline_submit"],
              "requirements": {
                "any_of": [
                  {
                    "all_of": [
                      {
                        "proof_type": "proof_of_human",
                        "provider": "world_id",
                        "min_assurance": "high"
                      }
                    ]
                  }
                ]
              },
              "binding": {
                "case_id": true,
                "action": true,
                "challenge": "support-reset-proof-challenge",
                "freshness_seconds": 300,
                "expires_at": "2026-03-26T12:20:00Z",
                "single_use": true
              },
              "fallback": {
                "on_missing": "browser_review",
                "on_invalid": "browser_review"
              }
            },
            "type": "confirmation",
            "prompt": "Confirm sending a password reset to customer #54981",
            "timeout": "20m",
            "default_action": "abort",
            "created_at": "2026-03-26T12:00:00Z",
            "expires_at": "2026-03-26T12:20:00Z"
          }
        }
      }
    },
    {
      "step": 2,
      "description": "Compliant agent preflights verification_policy, cannot satisfy it in the current channel, and sends the browser review link instead of attempting inline submit.",
      "agent_action": {
        "channel": "slack",
        "message": "Please complete this confirmation in the secure review page: https://support.example/review/support_u7v8w9x0?token=H1jK3lM5nO7pQ9rS1tU3vW5xY7zA9bC1dE3fG5h"
      }
    },
    {
      "step": "2b",
      "description": "Alternative non-compliant behavior: if an agent ignores preflight and tries inline submit without proof, the service returns 403 verification_required with a browser fallback.",
      "alternative_request": {
        "method": "POST",
        "url": "https://api.support.example/v1/reviews/support_u7v8w9x0/submit",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer agt_J1kL3mN5pQ7rS9tU1vW3xY5zA7bC9dE1fG3hI5j"
        },
        "body": {
          "action": "confirm",
          "data": {},
          "submitted_via": "slack_block_action",
          "submitted_by": {
            "platform": "slack",
            "platform_user_id": "U0123456789",
            "display_name": "Alex M."
          }
        }
      },
      "alternative_response": {
        "status": 403,
        "body": {
          "error": "verification_required",
          "message": "Inline submit requires proof_of_human. Use the review page.",
          "case_id": "review_support_u7v8w9x0",
          "review_url": "https://support.example/review/support_u7v8w9x0"
        }
      }
    },
    {
      "step": 3,
      "description": "After the human completes the browser flow, the poll response shows browser_submit and a normalized verification_result.",
      "request": {
        "method": "GET",
        "url": "https://api.support.example/v1/reviews/support_u7v8w9x0/status",
        "headers": {
          "Authorization": "Bearer sk_agent_support_u7v8w9x0"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "status": "completed",
          "case_id": "review_support_u7v8w9x0",
          "created_at": "2026-03-26T12:00:00Z",
          "opened_at": "2026-03-26T12:01:20Z",
          "expires_at": "2026-03-26T12:20:00Z",
          "completed_at": "2026-03-26T12:03:11Z",
          "result": {
            "action": "confirm",
            "data": {}
          },
          "responded_by": {
            "name": "Alex Mueller",
            "email": "alex.mueller@example.com"
          },
          "submission_context": {
            "mode": "browser_submit",
            "verification_result": {
              "satisfied": true,
              "verified_evidence": [
                {
                  "proof_type": "proof_of_human",
                  "provider": "world_id",
                  "assurance_level": "high",
                  "bound_to_case": true,
                  "bound_to_action": true,
                  "fresh": true,
                  "single_use_enforced": true
                }
              ],
              "missing_requirements": []
            }
          }
        }
      }
    }
  ]
}
